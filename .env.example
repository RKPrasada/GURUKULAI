# ── LLM ───────────────────────────────────────────────────────────────────────
# Required. Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Google OAuth (optional — use /api/student/demo without these) ─────────────
# Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ── YouTube Data API v3 (optional — no videos shown without this) ─────────────
# Cloud Console → Credentials → API Key → restrict to YouTube Data API v3
YOUTUBE_API_KEY=

# ── Google Workspace service accounts (optional — offline fallback without) ───
# Paste the full JSON content of a service account key file on one line
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_CALENDAR_CREDENTIALS_JSON=
GOOGLE_GMAIL_CREDENTIALS_JSON=

# ── Security ───────────────────────────────────────────────────────────────────
# Generate: python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./vidyabot.db
AUDIT_LOG_PATH=data/audit.jsonl

# GCS bucket for Cloud Run persistence (leave blank for local dev — no-op without it)
# Setup: gsutil mb -l asia-south1 gs://gurukulai-data
# IAM:   grant roles/storage.objectAdmin to the Cloud Run service account
GCS_DATA_BUCKET=

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
API_BASE_URL=http://localhost:8000
